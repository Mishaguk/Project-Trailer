<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.mishaguk.projecttrailer</id>
    <name>ProjectTrailer</name>
    <vendor>Who_knows</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.ProjectTrailerBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Project Trailer"
                    anchor="right"
                    icon="/icons/tour_icon.svg"
                    factoryClass="com.github.mishaguk.projecttrailer.toolWindow.ProjectTrailerToolWindowFactory" />
        <postStartupActivity
                implementation="com.github.mishaguk.projecttrailer.startup.ProjectTrailerStartupActivity" />
    </extensions>
</idea-plugin>
